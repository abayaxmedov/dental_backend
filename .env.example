# Django Settings
ENVIRONMENT=production
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,server-ip
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=dental
DB_USER=dental_user
DB_PASSWORD=change_me
DB_HOST=db
DB_PORT=5432

# Auth User Model
AUTH_USER_MODEL=accounts.CustomUser

# Localization
LANGUAGE_CODE=uz
TIME_ZONE=Asia/Tashkent

# Static & Media
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://frontend.your-domain.com

# CSRF
CSRF_TRUSTED_ORIGINS=http://your-domain.com,http://www.your-domain.com

# OpenAPI docs server url
API_BASE_URL=http://your-domain.com

# JWT Settings (optional customization)
JWT_ACCESS_TOKEN_LIFETIME_DAYS=7
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# Gunicorn
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=90
